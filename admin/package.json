{
    "name": "@lit/lit-starter-ts",
    "private": true,
    "version": "2.0.3",
    "description": "A simple web component",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "clean": "rimraf /build/*.{d.ts,d.ts.map,js,js.map}",
        "lint": "npm run lint:lit-analyzer && npm run lint:eslint",
        "lint:eslint": "eslint 'src/**/*.ts'",
        "lint:lit-analyzer": "lit-analyzer",
        "format": "prettier \"**/*.{cjs,html,js,json,md,ts}\" --ignore-path ./.eslintignore --write",
        "analyze": "cem analyze --litelement --globs \"src/**/*.ts\"",
        "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --watch",
        "serve": "wds --watch -p 3000",
        "serve:prod": "MODE=prod npm run serve",
        "codegen": "node scripts/GraphQLCodeGenerator.cjs"
    },
    "keywords": [
        "web-components",
        "lit-element",
        "typescript",
        "lit"
    ],
    "author": "Google LLC",
    "license": "BSD-3-Clause",
    "dependencies": {
        "auth0-js": "^9.30.0",
        "graphql-http": "^1.22.4",
        "lit": "^3.2.0"
    },
    "devDependencies": {
        "@custom-elements-manifest/analyzer": "^0.6.3",
        "@open-wc/testing": "^4.0.0",
        "@types/auth0-js": "^9.21.6",
        "@types/nanographql": "^2.0.3",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.54.0",
        "@web/dev-server": "^0.4.6",
        "@web/dev-server-legacy": "^1.0.0",
        "@web/test-runner": "^0.20.2",
        "@web/test-runner-playwright": "^0.11.1",
        "@webcomponents/webcomponentsjs": "^2.8.0",
        "eslint": "^9.39.2",
        "lit-analyzer": "^2.0.3",
        "prettier": "^2.6.2",
        "rimraf": "^3.0.2",
        "rollup": "^4.18.0",
        "rollup-plugin-summary": "^2.0.1",
        "typescript": "~5.9.0"
    },
    "customElements": "custom-elements.json"
}
